<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.fraguns.cron</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/curl</string>
        <string>-s</string>
        <string>-H</string>
        <string>Authorization: Bearer ***REMOVED-SECRET***</string>
        <string>https://fraguns.vercel.app/api/cron/daily</string>
    </array>
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/fraguns-cron.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/fraguns-cron.log</string>
</dict>
</plist>
